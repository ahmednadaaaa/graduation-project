# ==============================================================================
# .env.production.example
# Copy to EC2: cp deployment/.env.production.example .env.production
# Fill in the actual secret values on the server.
# ==============================================================================

# ── Django Settings ──────────────────────────────────────────────────────────
# Set Django to production settings
DJANGO_SETTINGS_MODULE=unitrack.settings.production

# Generate a secure secret key for production (e.g. using openssl rand -hex 32)
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# Comma-separated list of allowed domains or IPs
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-ec2-ip-address,localhost

# ── PostgreSQL Database Settings ──────────────────────────────────────────────
# In production, these are automatically set by setup_production.sh but can be customized here
DB_NAME=unitrack
DB_USER=unitrack
DB_PASSWORD=replace-with-your-generated-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Redis (WebSockets Channel Layer & Celery Broker) ──────────────────────────
# Local Redis server URL (configured by setup_production.sh)
REDIS_URL=redis://127.0.0.1:6379/0

# ── Third Party API Keys ──────────────────────────────────────────────────────
# Put your Google Maps API key here for real-time tracking page
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ── Email Settings (SMTP) ─────────────────────────────────────────────────────
# Configure your production mail service (e.g. Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=UniTrack <noreply@yourdomain.com>
